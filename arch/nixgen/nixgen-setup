#!/bin/sh -e
# Install the running system onto a disk, from inside the box: GPT
# (ESP + NIXSTORE ext4), standalone UEFI GRUB that only sources
# entries.cfg from the store partition, fresh store seeded with a
# commit of the running root: shape the system first, install what you
# actually run. Firmware boots the
# removable path (EFI/BOOT/BOOTX64.EFI), no NVRAM entry needed.
# UEFI only, Secure Boot off. Everything on the target is lost; the
# device path must be typed back. GRUB finds the store by label: if
# the installer medium is itself a NIXSTORE disk (flashed stick),
# unplug it before first boot.
# usage: nixgen-setup <device> [name] [--fs <type>]
#        name default nixarch-install, fs default ext4 (nixgen-fs holds
#        the filesystem table; GRUB has to be able to read the store, so
#        the choice is between the journalling/CoW ones, not FAT)
. /usr/local/lib/nixgen-fs

DEV= NAME= FS=ext4
while [ $# -gt 0 ]; do
	case $1 in
	--fs) FS=$2; shift 2 ;;
	--fs=*) FS=${1#--fs=}; shift ;;
	-*) echo "unknown option: $1" >&2; exit 1 ;;
	*)
		if [ -z "$DEV" ]; then DEV=$1; else NAME=$1; fi
		shift
		;;
	esac
done
NAME=${NAME:-nixarch-install}
# filesystem first: a typo there is worth naming on its own, before the
# device check turns it into a usage dump
is_supported_fs "$FS" || exit 1
[ -b "$DEV" ] || {
	# the list comes from the table, so a filesystem added there shows
	# up here without touching this script
	echo "usage: $0 <device> [name] [--fs <type>]" >&2
	echo "  <type>: $(echo "$NIXGEN_FS_ALL" | tr ' ' '|') (default ext4)" >&2
	for f in $NIXGEN_FS_ALL; do
		printf '  %-6s mkfs from %s\n' "$f" "$(fs_pkg "$f")" >&2
	done
	exit 1
}
case $DEV in
*[0-9]) PART="${DEV}p" ;;
*) PART="$DEV" ;;
esac

# covers the running store disk and the boot medium: both are mounted
if grep -q "^$DEV" /proc/mounts; then
	echo "refusing: $DEV has mounted partitions" >&2
	exit 1
fi

lsblk -dn -o NAME,SIZE,MODEL,TRAN "$DEV"
printf 'everything on %s will be lost. type the device path to continue: ' "$DEV"
read -r reply
[ "$reply" = "$DEV" ] || { echo "aborted"; exit 1; }

# install is rare: its deps stay out of the generations and land in
# the ephemeral upper on demand (gone at reboot unless committed).
# Plain -S against the generation's baked db: versions match the
# running snapshot, no partial upgrade (-Sy <pkg> is never right). A
# stale generation's versions may be gone from live mirrors; the
# consistent way forward is a full update, not a db refresh here
pacman -S --needed --noconfirm grub dosfstools "$(fs_pkg "$FS")" || {
	echo "setup: dep install failed (stale generation?);" \
		"nixgen-update + reboot, then retry" >&2
	exit 1
}

sfdisk -q "$DEV" <<EOF
label: gpt
start=1MiB, size=64MiB, type=uefi
start=65MiB, type=linux
EOF
udevadm settle --timeout=10
mkfs.fat -F 32 -n NIXBOOT "${PART}1"
fs_mkfs "$FS" "${PART}2" NIXSTORE

T=$(mktemp -d /run/nixgen-setup.XXXXXX)
cleanup() {
	for m in "$T/esp" "$T/store"; do
		if mountpoint -q "$m"; then
			umount "$m"
		fi
	done
	rm -rf "$T"
}
trap cleanup EXIT
mkdir "$T/esp" "$T/store"

# GRUB's whole job is finding the store partition and deferring to its
# entries.cfg, which commit/update/adopt append to
cat > "$T/embed.cfg" <<EOF
set default=0
set timeout=5
insmod part_gpt
search --no-floppy --set=nixdev --label NIXSTORE
if [ -n "\$nixdev" ]; then
	source (\$nixdev)/entries.cfg
else
	echo "NIXSTORE partition not found"
fi
EOF
grub-mkstandalone -O x86_64-efi --locales= --themes= \
	-o "$T/BOOTX64.EFI" "boot/grub/grub.cfg=$T/embed.cfg"

mount "${PART}1" "$T/esp"
install -D "$T/BOOTX64.EFI" "$T/esp/EFI/BOOT/BOOTX64.EFI"
umount "$T/esp"

mount "${PART}2" "$T/store"
/usr/local/bin/nixgen-commit "$NAME" "$T/store"
umount "$T/store"

echo "installed: $NAME on $DEV (unplug the installer medium, reboot)"
