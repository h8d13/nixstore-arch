#!/bin/sh -e
# Replay metadata the store canonicalisation stripped, captured by
# nixgen-savemeta in etc/nixgen/{perms,caps,acls}: directory modes,
# special mode bits (setuid/sticky/...), non-root ownership (symlinks
# included), capability xattrs, POSIX ACLs. On the booted overlay each
# touched path is a metadata-only copy-up into the tmpfs upper. Also
# run inside build sandboxes right after the overlay mount, so pacman
# sees the modes it expects (no "directory permissions differ"
# warnings against the 0555 store lower).
# usage: nixgen-restmeta [root]   (default /; run by nixgen-perms.service)
R=${1:-/}
M=$R/etc/nixgen/perms
[ -f "$M" ] || exit 0
cd "$R"

# batch chmod per distinct mode value: dirs dominate the manifest and
# collapse to a handful of exec calls. Symlink rows are skipped:
# their mode is meaningless and chmod would follow the link.
# Fail soft: commit snapshots a live root, so a row can outlive its
# file (a service's PrivateTmp dir vanished mid-commit); one stale row
# aborting the whole replay (sh -e) left /home unowned once
awk -F'\t' '$1 != "l" { print $2 }' "$M" | sort -u | while read -r mode; do
	awk -F'\t' -v m="$mode" '$1 != "l" && $2 == m { print $5 }' "$M" \
		| tr '\n' '\0' | xargs -0 -r chmod "$mode" \
		|| echo "restmeta: some mode-$mode paths skipped" >&2
done

# ownership deviations are few, applied one by one; -h never follows
# symlinks. In a single-uid userns sandbox non-zero uids have no
# mapping and must fail soft; the booted box is real root and applies
# them all
awk -F'\t' '$3 != 0 || $4 != 0 { print $3 ":" $4 " " $5 }' "$M" \
	| while read -r own p; do
		chown -h "$own" "$p" || echo "restmeta: chown $own $p skipped" >&2
	done

C=$R/etc/nixgen/caps
if [ -s "$C" ]; then
	while read -r p caps; do
		setcap "$caps" "$p" || echo "restmeta: setcap $p skipped" >&2
	done < "$C"
fi

A=$R/etc/nixgen/acls
if [ -s "$A" ]; then
	# -P: rows are physical paths (getfacl -R capture); following a
	# symlink component would apply an ACL outside the tree
	setfacl -P --restore="$A" || echo "restmeta: some ACLs skipped" >&2
fi
