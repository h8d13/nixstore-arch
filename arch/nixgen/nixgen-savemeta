#!/bin/sh -e
# Capture filesystem metadata that store import will canonicalise away
# (every dir becomes 0555 root:root, files lose special bits and
# ownership, all xattrs vanish: NAR keeps only the executable bit) as
# plain data inside the tree: etc/nixgen/perms (type, mode, owner per
# deviating path; symlink rows are ownership-only), etc/nixgen/caps
# (getcap text: raw capability xattrs are userns-encoded, they must
# round-trip through setcap to normalise), etc/nixgen/acls (getfacl
# numeric dump). Being content, the manifests are hashed and deduped
# with the generation and roll back with it. nixgen-restmeta replays
# them at boot and in build sandboxes.
# Plain-file mode diffs (644 vs canonical 444) are skipped on purpose:
# owner is root, root bypasses modes, and restoring them would
# metadata-copy-up every file instead of a few dozen paths.
# usage: nixgen-savemeta <root>
R=$1
[ -d "$R" ] || { echo "usage: $0 <root>" >&2; exit 1; }
cd "$R"
mkdir -p etc/nixgen
# ! -perm -444: canonical 0444 makes every file world-readable, so
# files STRICTER than that (shadow, ssh host keys, 600/640/440) must
# be captured or import discloses them to non-root users
find . -xdev \( -type d ! \( -perm 555 -user 0 -group 0 \) \
	-o -type f \( -perm /7022 -o ! -perm -444 -o ! -user 0 -o ! -group 0 \) \
	-o -type l ! \( -user 0 -group 0 \) \) \
	-printf '%y\t%m\t%U\t%G\t%p\n' | sort -t'	' -k5 > etc/nixgen/perms
getcap -r . > etc/nixgen/caps
# -s: only paths carrying extended/default ACLs; numeric ids stay
# resolution-independent like the perms manifest
getfacl -Rsp --numeric . > etc/nixgen/acls
