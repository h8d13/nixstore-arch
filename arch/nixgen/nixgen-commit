#!/bin/sh -e
# Commit the running system as a new generation, from inside the box.
# Needs a NIXSTORE disk attached (/nixstoredev mounted by the nixgen
# initramfs hook); a blank one gets a store initialized on first commit.
# Snapshots the merged root via a non-recursive bind (submounts like
# /proc, /run, /nixstore fall away), imports it content-addressed,
# appends a GRUB entry on the store disk.
# usage: nixgen-commit <name> [store-root]
#        store-root default /nixstoredev; nixgen-setup passes a freshly
#        formatted target to seed an install
NAME=$1
TARGET=${2:-/nixstoredev}
[ -n "$NAME" ] || { echo "usage: $0 <name> [store-root]" >&2; exit 1; }
[ -d "$TARGET" ] || {
	echo "no writable store at $TARGET: boot with a NIXSTORE disk attached" >&2
	exit 1
}

SNAP=/run/nixgen-snap
mkdir -p "$SNAP"
mount --bind / "$SNAP"
trap 'umount "$SNAP"' EXIT

# NAR can't represent sockets/fifos; these are runtime droppings (gpg
# agent et al) so deleting them from the live root is fine
find "$SNAP" \( -type s -o -type p \) -print -delete
# cached downloads are not system state (nixgen-update scrubs the same);
# this deletes from the live root, like the socket scrub above
[ ! -d "$SNAP/var/cache/pacman/pkg" ] || \
	find "$SNAP/var/cache/pacman/pkg" -mindepth 1 -delete

# import materialises the full un-deduped snapshot in the store before
# optimise hardlinks it; without room for that peak it dies mid-stream
# (ENOSPC). du undercounts vs NAR (hardlinks once), treat as a floor
NEED=$(du -sxm "$SNAP" | cut -f1)
FREE=$(df -Pm "$TARGET" | awk 'NR==2 { print $4 }')
[ "$FREE" -ge "$NEED" ] || {
	echo "not enough space on $TARGET: snapshot needs ~${NEED}M" \
		"un-deduped, ${FREE}M free (nixgen-remove old generations?)" >&2
	exit 1
}

/usr/local/bin/nixgen-savemeta "$SNAP"
# import-dir stdout is exactly the store path; mtime-based selection
# (ls -t) cannot work, every store path's mtime is canonicalised to 1
NEW=$(LD_LIBRARY_PATH=/usr/local/lib /usr/local/bin/import-dir \
	"$TARGET" "$NAME" "$SNAP")
GEN=$(basename "$NEW")

# new entry boots with the same kernel params as the running system,
# minus the generation selector and GRUB's own bookkeeping
CMDLINE=$(tr ' ' '\n' < /proc/cmdline \
	| grep -v '^nixgen=\|^nixsource=\|^BOOT_IMAGE=\|^initrd=\|^$' | tr '\n' ' ')

cat >> "$TARGET/entries.cfg" <<EOF
menuentry "nixarch: $GEN (committed)" {
	search --no-floppy --set=nixdev --label NIXSTORE
	linux (\$nixdev)/nix/store/$GEN/boot/vmlinuz-linux nixgen=$GEN nixsource=disk $CMDLINE
	initrd (\$nixdev)/nix/store/$GEN/boot/initramfs-linux.img
}
EOF
echo "committed: $GEN (GRUB entry added, visible next boot)"
